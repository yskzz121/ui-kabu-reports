<script>
const chartFont={family:'Inter',size:12};
Chart.defaults.color='#8b949e';
Chart.defaults.font=chartFont;
const gridOpt={color:'rgba(48,54,61,0.5)'};

// 売上高 7四半期
new Chart(document.getElementById('revChart'),{
  type:'bar',
  data:{
    labels:['Q3 24','Q4 24','Q1 25','Q2 25','Q3 25','Q4 25','Q1 26'],
    datasets:[{
      label:'Revenue (€M)',
      data:[7467,9263,7742,7692,7516,9718,8767],
      backgroundColor:['rgba(184,145,42,0.4)','rgba(184,145,42,0.4)','rgba(184,145,42,0.45)','rgba(184,145,42,0.45)','rgba(184,145,42,0.5)','rgba(184,145,42,0.6)','rgba(212,168,67,0.75)'],
      borderColor:['#B8912A','#B8912A','#B8912A','#B8912A','#B8912A','#B8912A','#D4A843'],
      borderWidth:1,borderRadius:6
    }]
  },
  options:{
    responsive:true,maintainAspectRatio:false,
    plugins:{
      legend:{display:false},
      title:{display:true,text:'Revenue（直近7四半期, €M）',color:'#e6edf3',font:{size:13,weight:'700'}},
      tooltip:{callbacks:{label:ctx=>'€'+ctx.parsed.y.toLocaleString()+'M'}}
    },
    scales:{y:{grid:gridOpt,ticks:{callback:v=>'€'+(v/1000).toFixed(1)+'B'},min:7000},x:{grid:{display:false}}}
  }
});

// EPS 7四半期
new Chart(document.getElementById('epsChart'),{
  type:'bar',
  data:{
    labels:['Q3 24','Q4 24','Q1 25','Q2 25','Q3 25','Q4 25','Q1 26'],
    datasets:[{
      label:'EPS (€)',
      data:[5.28,6.84,6.00,5.90,5.48,7.34,7.15],
      backgroundColor:['rgba(88,166,255,0.4)','rgba(88,166,255,0.5)','rgba(88,166,255,0.5)','rgba(88,166,255,0.5)','rgba(88,166,255,0.5)','rgba(63,185,80,0.6)','rgba(212,168,67,0.75)'],
      borderColor:['#58a6ff','#58a6ff','#58a6ff','#58a6ff','#58a6ff','#3fb950','#D4A843'],
      borderWidth:1,borderRadius:6
    }]
  },
  options:{
    responsive:true,maintainAspectRatio:false,
    plugins:{
      legend:{display:false},
      title:{display:true,text:'EPS（直近7四半期, €）',color:'#e6edf3',font:{size:13,weight:'700'}},
      tooltip:{callbacks:{label:ctx=>'€'+ctx.parsed.y.toFixed(2)}}
    },
    scales:{y:{grid:gridOpt,ticks:{callback:v=>'€'+v.toFixed(1)},min:5},x:{grid:{display:false}}}
  }
});

// 利益率トレンド（参考: 過去数値は推定を含む）
new Chart(document.getElementById('marginChart'),{
  type:'line',
  data:{
    labels:['Q3 24','Q4 24','Q1 25','Q2 25','Q3 25','Q4 25','Q1 26'],
    datasets:[
      {label:'粗利益率 (%)',data:[50.8,51.7,54.0,53.7,51.6,51.0,53.0],borderColor:'#D4A843',fill:false,tension:.3,pointRadius:4},
      {label:'営業利益率 (%)',data:[32.7,35.3,33.0,34.4,32.0,34.0,36.0],borderColor:'#58a6ff',fill:false,tension:.3,pointRadius:4},
      {label:'純利益率 (%)',data:[28.2,29.9,28.5,29.5,27.0,30.0,31.9],borderColor:'#bc8cff',fill:false,tension:.3,pointRadius:4,borderDash:[5,3]}
    ]
  },
  options:{
    responsive:true,maintainAspectRatio:false,
    plugins:{
      tooltip:{callbacks:{label:ctx=>ctx.dataset.label+': '+ctx.parsed.y.toFixed(1)+'%'}},
      title:{display:true,text:'粗利益率 / 営業利益率 / 純利益率 推移',color:'#e6edf3',font:{size:13,weight:'700'}}
    },
    scales:{y:{grid:gridOpt,ticks:{callback:v=>v+'%'},min:20,max:60},x:{grid:{display:false}}}
  }
});
</script>

