<script>
// Accordion
var touchStartY=0,touchStartX=0,touchStartTime=0;
function toggleAccordion(sec){
  if(!sec)return;
  var isCollapsed=sec.classList.contains('collapsed');
  if(isCollapsed){
    sec.classList.remove('collapsed');
    sec.classList.add('collapsing');
    var body=sec.querySelector('.section-body');
    var onEnd=function(){sec.classList.remove('collapsing');body.removeEventListener('transitionend',onEnd);};
    body.addEventListener('transitionend',onEnd);
    setTimeout(function(){sec.classList.remove('collapsing');},400);
  }else{
    sec.classList.add('collapsing','collapsed');
    var body2=sec.querySelector('.section-body');
    var onEnd2=function(){sec.classList.remove('collapsing');body2.removeEventListener('transitionend',onEnd2);};
    body2.addEventListener('transitionend',onEnd2);
    setTimeout(function(){sec.classList.remove('collapsing');},400);
  }
}
document.querySelectorAll('[data-accordion] .section-title').forEach(function(title){
  title.addEventListener('touchstart',function(e){touchStartY=e.touches[0].clientY;touchStartX=e.touches[0].clientX;touchStartTime=Date.now();},{passive:true});
  title.addEventListener('touchend',function(e){
    var dy=Math.abs(e.changedTouches[0].clientY-touchStartY);
    var dx=Math.abs(e.changedTouches[0].clientX-touchStartX);
    var dt=Date.now()-touchStartTime;
    if(dy<10&&dx<10&&dt<300){e.preventDefault();toggleAccordion(this.closest('[data-accordion]'));}
  });
  title.addEventListener('click',function(e){
    if(e.sourceCapabilities&&e.sourceCapabilities.firesTouchEvents)return;
    if(window.matchMedia('(pointer:fine)').matches){toggleAccordion(this.closest('[data-accordion]'));}
  });
});
(function(){if(window.innerWidth<=768){document.querySelectorAll('[data-accordion]').forEach(function(sec){sec.classList.add('collapsed');});}})();

// TOC
function toggleToc(){
  var menu=document.getElementById('tocMenu');
  var btn=document.getElementById('tocToggle');
  menu.classList.toggle('open');
  btn.classList.toggle('open');
  btn.textContent=menu.classList.contains('open')?'✕ セクション':'☰';
}
function tocJump(id){
  var sec=document.getElementById(id);
  if(sec){sec.classList.remove('collapsed');toggleToc();setTimeout(function(){sec.scrollIntoView({behavior:'smooth',block:'start'});},100);}
}
function toggleAllSections(expand){
  document.querySelectorAll('[data-accordion]').forEach(function(sec){
    if(expand)sec.classList.remove('collapsed');else sec.classList.add('collapsed');
  });
}

// Overview
function toggleOverview(){
  var dd=document.getElementById('overviewDropdown');
  var btn=document.getElementById('overviewToggleBtn');
  if(!dd||!btn)return;
  dd.classList.toggle('open');
  btn.classList.toggle('open');
}
</script>

<!-- Currency Toggle (Atlas shared) -->
<script>
(function(){
  if(window.__ATLAS_CURRENCY_LOADED) return;
  window.__ATLAS_CURRENCY_LOADED = true;
  var FX = window.ATLAS_FX;
  if(!FX || !FX.code || FX.code === 'USD'){
    document.addEventListener('DOMContentLoaded', function(){
      document.querySelectorAll('.currency-toggle').forEach(function(b){ b.style.display = 'none'; });
    });
    window.toggleCurrency = function(){}; return;
  }
  if(!FX.symbol) FX.symbol = '¥';
  if(!FX.fmt) FX.fmt = 'cjk-ja';
  var localKey = 'atlas-currency';
  var currencyMode = localStorage.getItem(localKey) || 'USD';
  if(currencyMode !== 'USD' && currencyMode !== FX.code) currencyMode = FX.code;

  function fmtLocal(amt, unit, sym){
    var rate = (sym === '€' && FX.eurRate) ? FX.eurRate : FX.rate;
    var amt_b = unit==='T'?amt*1000:unit==='B'?amt:unit==='M'?amt/1000:unit==='K'?amt/1e6:null;
    if(FX.fmt === 'cjk-ja'){
      if(amt_b !== null){
        var jpy_b = amt_b * rate;
        if(jpy_b >= 1000) return FX.symbol + (jpy_b/1000).toFixed(2) + '兆';
        if(jpy_b >= 1) return FX.symbol + (jpy_b*10).toFixed(0) + '億';
        return FX.symbol + (jpy_b*1000).toFixed(0) + '百万';
      }
      var jpy = amt * rate;
      if(jpy >= 10000) return FX.symbol + (jpy/10000).toFixed(2) + '万';
      return FX.symbol + Math.round(jpy).toLocaleString();
    }
    return FX.symbol + Math.round(amt * rate).toLocaleString();
  }

  var WRAP_DONE = false;
  function wrapCurrencyValues(){
    if(WRAP_DONE) return; WRAP_DONE = true;
    var re = /([\$€])(\d+(?:,\d{3})*(?:\.\d+)?)\s*([TBMK])?(?![\w%])/g;
    var skipTags = {SCRIPT:1,STYLE:1,NOSCRIPT:1,BUTTON:1,A:1};
    var skipClasses = ['portal-link','currency-toggle','theme-toggle-btn','toc-toggle','toc-list','tradingview-widget-container','no-currency','overview-toggle-btn'];
    function shouldSkip(node){
      var p = node.parentNode;
      while(p && p !== document.body){
        if(skipTags[p.tagName]) return true;
        if(p.classList){ for(var i=0;i<skipClasses.length;i++) if(p.classList.contains(skipClasses[i])) return true; }
        p = p.parentNode;
      }
      return false;
    }
    var walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, null, false);
    var nodes = [], n;
    while((n = walker.nextNode())){ if(n.nodeValue && (n.nodeValue.indexOf('$') >= 0 || n.nodeValue.indexOf('€') >= 0) && !shouldSkip(n)) nodes.push(n); }
    nodes.forEach(function(node){
      var text = node.nodeValue;
      if(!re.test(text)) return;
      re.lastIndex = 0;
      var frag = document.createDocumentFragment();
      var lastIdx = 0, m;
      while((m = re.exec(text)) !== null){
        if(m.index > lastIdx) frag.appendChild(document.createTextNode(text.slice(lastIdx, m.index)));
        var sym = m[1];
        var num = parseFloat(m[2].replace(/,/g,''));
        var unit = m[3] || '';
        var span = document.createElement('span');
        span.className = 'cur-val';
        span.setAttribute('data-sym', sym);
        span.setAttribute('data-usd', num);
        span.setAttribute('data-unit', unit);
        span.setAttribute('data-orig', m[0]);
        span.textContent = m[0];
        frag.appendChild(span);
        lastIdx = m.index + m[0].length;
      }
      if(lastIdx < text.length) frag.appendChild(document.createTextNode(text.slice(lastIdx)));
      node.parentNode.replaceChild(frag, node);
    });
  }

  function applyCurrency(mode){
    document.querySelectorAll('.cur-val').forEach(function(el){
      if(mode !== 'USD'){
        var usd = parseFloat(el.getAttribute('data-usd'));
        var unit = el.getAttribute('data-unit') || '';
        var sym = el.getAttribute('data-sym') || '$';
        el.textContent = fmtLocal(usd, unit, sym);
        el.classList.add('local-mode','jpy-mode');
      } else {
        el.textContent = el.getAttribute('data-orig');
        el.classList.remove('local-mode','jpy-mode');
      }
    });
    document.querySelectorAll('.currency-toggle').forEach(function(btn){
      var act = btn.querySelector('.cur-active');
      var inact = btn.querySelector('.cur-inactive');
      if(!act || !inact) return;
      if(mode !== 'USD'){
        btn.classList.add('local-mode','jpy-mode');
        act.textContent = FX.symbol; inact.textContent = '$';
        btn.title = FX.code + '表示中（レート: 1$ = ' + FX.rate + ' ' + FX.code + '、' + FX.date + '）';
      } else {
        btn.classList.remove('local-mode','jpy-mode');
        act.textContent = '$'; inact.textContent = FX.symbol;
        btn.title = 'USD ⇄ ' + FX.code + ' 切替（レート: 1$ = ' + FX.rate + ' ' + FX.code + '、' + FX.date + '）';
      }
    });
  }

  function initButtons(){
    document.querySelectorAll('.currency-toggle').forEach(function(btn){
      var inact = btn.querySelector('.cur-inactive');
      if(inact && inact.textContent === '¥') inact.textContent = FX.symbol;
    });
  }

  window.toggleCurrency = function(){
    wrapCurrencyValues();
    currencyMode = currencyMode === 'USD' ? FX.code : 'USD';
    localStorage.setItem(localKey, currencyMode);
    applyCurrency(currencyMode);
  };

  document.addEventListener('DOMContentLoaded', function(){
    initButtons();
    if(currencyMode !== 'USD'){ wrapCurrencyValues(); applyCurrency(currencyMode); }
    else { applyCurrency('USD'); }
  });
})();
</script>

<!-- Theme Toggle -->
<script>
(function(){
  var html = document.documentElement;
  var KEY = 'atlas-theme';
  function applyTheme(t){
    if(t === 'light'){ html.setAttribute('data-theme','light'); }
    else { html.removeAttribute('data-theme'); }
    document.querySelectorAll('.theme-toggle-btn').forEach(function(b){
      b.textContent = (t === 'light') ? '🌙' : '☀️';
      b.title = (t === 'light') ? 'ダークモードに切替' : 'ライトモードに切替';
    });
  }
  var saved = localStorage.getItem(KEY) || 'dark';
  applyTheme(saved);
  window.toggleAtlasTheme = function(){
    var cur = localStorage.getItem(KEY) || 'dark';
    var next = cur === 'dark' ? 'light' : 'dark';
    localStorage.setItem(KEY, next);
    applyTheme(next);
  };
})();
</script>

<!-- ATLAS-PAYWALL-SCRIPT -->
<script>
/*!
 * Atlas Paywall — Phase 1 (client-side MVP)
 *
 * 各ページの <meta name="atlas-access" content='{"kind":"...","...":...}'> を読み、
 * 非会員に対して overlay または truncate を表示する。
 *
 * kind:
 *   - "morning"  : date (YYYY-MM-DD) を持つ。今日/昨日なら free、それ以外は gated
 *   - "extra"    : 常に truncate（本文文字数の1/3だけ無料公開）
 *   - "special"  : 常に gated（冒頭プレビュー以外は非表示）
 *   - "report"   : ticker + isLatest。flagship かつ latest なら free、それ以外は gated
 *
 * 会員判定:
 *   - cookie `atlas_session` 無し → ゲスト（free制限あり）
 *   - cookie あり → /api/me を fetch。plan_expires_at > now なら Pro（制限なし）
 *
 * デバッグ:
 *   - URLに ?atlas-debug=pro  → 強制Pro扱い
 *   - URLに ?atlas-debug=free → 強制Free扱い
 */
(function () {
  var FLAGSHIP = { NVDA: 1, GOOGL: 1, TSLA: 1, MSFT: 1, META: 1, AMZN: 1, AAPL: 1 };
  var MORNING_FREE_DAYS = 2;       // today + yesterday = 2 calendar days
  var EXTRA_FREE_FRACTION = 1 / 3; // 号外: 本文文字数の1/3

  function readAccess() {
    var meta = document.querySelector('meta[name="atlas-access"]');
    if (!meta) return null;
    try { return JSON.parse(meta.getAttribute('content') || '{}'); }
    catch (e) { return null; }
  }

  function daysAgoJST(ymd) {
    // ymd: "2026-04-15". Compare JST midnight to JST midnight.
    if (!ymd || !/^\d{4}-\d{2}-\d{2}$/.test(ymd)) return Infinity;
    var parts = ymd.split('-').map(Number);
    var pubUTC = Date.UTC(parts[0], parts[1] - 1, parts[2]);
    var now = new Date();
    // JST = UTC+9. Midnight JST today = today's UTC date at 15:00 prev day in UTC.
    var jstNow = new Date(now.getTime() + 9 * 3600 * 1000);
    var jstToday = Date.UTC(jstNow.getUTCFullYear(), jstNow.getUTCMonth(), jstNow.getUTCDate());
    return Math.floor((jstToday - pubUTC) / 86400000);
  }

  function resolveStatus(cfg) {
    if (!cfg || !cfg.kind) return 'full';
    if (cfg.kind === 'morning') {
      var diff = daysAgoJST(cfg.date);
      return diff < MORNING_FREE_DAYS ? 'full' : 'gated';
    }
    if (cfg.kind === 'extra') return 'truncate';
    if (cfg.kind === 'special') return 'gated';
    if (cfg.kind === 'report') {
      if (cfg.isLatest && FLAGSHIP[cfg.ticker]) return 'full';
      return 'gated';
    }
    return 'full';
  }

  function hasSession() {
    return document.cookie.split(';').some(function (c) { return /^\s*atlas_session=/.test(c); });
  }

  function getDebugOverride() {
    var m = location.search.match(/[?&]atlas-debug=(pro|free)/);
    return m ? m[1] : null;
  }

  function checkPro() {
    return new Promise(function (resolve) {
      var dbg = getDebugOverride();
      if (dbg === 'pro') return resolve(true);
      if (dbg === 'free') return resolve(false);
      if (!hasSession()) return resolve(false);
      var ctrl = typeof AbortController !== 'undefined' ? new AbortController() : null;
      if (ctrl) setTimeout(function () { try { ctrl.abort(); } catch(e){} }, 3000);
      fetch('/api/me', { credentials: 'include', signal: ctrl ? ctrl.signal : undefined })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (data) {
          if (!data || !data.user) return resolve(false);
          // plan が 'pro' 以外は Pro 非会員
          if (data.user.plan !== 'pro') return resolve(false);
          // plan_expires_at が null → 解約予約無し = Pro継続中
          var exp = data.user.plan_expires_at;
          if (!exp) return resolve(true);
          // 期限あり → 期限前なら Pro 有効
          resolve(new Date(exp) > new Date());
        })
        .catch(function () { resolve(false); });
    });
  }

  // === UI helpers ===
  var BASE_CSS =
    '.atlas-paywall-card{background:linear-gradient(135deg,#1A2540 0%,#0F1829 100%);border:1px solid rgba(184,145,42,.3);border-radius:12px;padding:36px 32px;margin:32px auto;max-width:600px;text-align:center;font-family:"Noto Sans JP",sans-serif;color:#fff;box-shadow:0 8px 24px rgba(0,0,0,.35)}' +
    '.atlas-paywall-card .apw-kicker{color:#D4A843;font-size:11px;letter-spacing:.15em;text-transform:uppercase;margin-bottom:12px;font-weight:700}' +
    '.atlas-paywall-card .apw-ttl{font-family:"Shippori Mincho B1",serif;font-size:22px;font-weight:700;line-height:1.45;margin-bottom:14px;color:#fff}' +
    '.atlas-paywall-card .apw-desc{font-size:13px;line-height:1.85;color:rgba(255,255,255,.75);margin-bottom:24px}' +
    '.atlas-paywall-card .apw-price{display:inline-block;background:rgba(184,145,42,.1);border:1px solid rgba(184,145,42,.35);border-radius:8px;padding:10px 18px;margin-bottom:20px;color:#D4A843;font-size:13px;font-weight:600;letter-spacing:.03em}' +
    '.atlas-paywall-card .apw-cta{display:inline-block;background:#B8912A;color:#0F1829;text-decoration:none;padding:13px 32px;border-radius:8px;font-weight:700;font-size:14px;letter-spacing:.04em;transition:background .15s}' +
    '.atlas-paywall-card .apw-cta:hover{background:#D4A843}' +
    '.atlas-paywall-card .apw-alt{display:block;margin-top:14px;color:rgba(255,255,255,.45);font-size:11px;text-decoration:none}' +
    '.atlas-paywall-card .apw-alt:hover{color:#D4A843}' +
    '.atlas-paywall-fade{position:relative;height:160px;margin-top:-160px;pointer-events:none;background:linear-gradient(to bottom,transparent 0%,rgba(13,17,23,.6) 55%,rgba(13,17,23,.98) 100%)}' +
    '.atlas-paywall-gated-hide{display:none!important}' +
    '.atlas-paywall-preview-wrap{position:relative;max-height:320px;overflow:hidden}' +
    '.atlas-paywall-preview-wrap::after{content:"";position:absolute;bottom:0;left:0;right:0;height:140px;background:linear-gradient(to bottom,transparent 0%,rgba(13,17,23,.6) 50%,rgba(13,17,23,.98) 100%);pointer-events:none}' +
    'html[data-theme="light"] .atlas-paywall-card{background:linear-gradient(135deg,#FDFCFA 0%,#F5F2EC 100%);color:#1A2540;border-color:rgba(26,37,64,.15)}' +
    'html[data-theme="light"] .atlas-paywall-card .apw-ttl{color:#1A2540}' +
    'html[data-theme="light"] .atlas-paywall-card .apw-desc{color:#4A5568}' +
    'html[data-theme="light"] .atlas-paywall-card .apw-price{background:rgba(184,145,42,.08);color:#8a6c1f;border-color:rgba(184,145,42,.25)}' +
    'html[data-theme="light"] .atlas-paywall-fade{background:linear-gradient(to bottom,transparent 0%,rgba(245,242,236,.6) 55%,rgba(245,242,236,.98) 100%)}' +
    'html[data-theme="light"] .atlas-paywall-preview-wrap::after{background:linear-gradient(to bottom,transparent 0%,rgba(245,242,236,.6) 50%,rgba(245,242,236,.98) 100%)}';

  function ensureCss() {
    if (document.getElementById('atlas-paywall-css')) return;
    var s = document.createElement('style');
    s.id = 'atlas-paywall-css';
    s.textContent = BASE_CSS;
    document.head.appendChild(s);
  }

  function buildCard(opts) {
    var url = '/login?redirect=' + encodeURIComponent(location.pathname + location.search);
    var div = document.createElement('div');
    div.className = 'atlas-paywall-card';
    div.setAttribute('data-atlas-paywall', opts.kind);
    div.innerHTML =
      '<div class="apw-kicker">' + (opts.kicker || 'Atlas 会員限定') + '</div>' +
      '<div class="apw-ttl">' + opts.title + '</div>' +
      '<div class="apw-desc">' + opts.desc + '</div>' +
      '<div class="apw-price">月額 ¥980（税込）・いつでも解約可能</div><br>' +
      '<a class="apw-cta" href="' + url + '">会員登録して続きを読む</a>' +
      '<a class="apw-alt" href="/login?redirect=' + encodeURIComponent(location.pathname + location.search) + '">すでに会員の方はログイン →</a>';
    return div;
  }

  function findArticleBody() {
    var selectors = [
      'main.main',
      'main.atlas-article-body',
      'article',
      'main',
      '.container',
      'body'
    ];
    for (var i = 0; i < selectors.length; i++) {
      var el = document.querySelector(selectors[i]);
      if (el) return el;
    }
    return document.body;
  }

  // Truncate body to N fraction of total text, insert paywall card.
  function applyTruncate(cfg) {
    ensureCss();
    var body = findArticleBody();
    // Find block-level content containers (direct children + deep)
    // We walk through direct children and compute cumulative text length.
    var children = Array.prototype.slice.call(body.children);
    var totalLen = body.textContent.replace(/\s+/g, '').length;
    if (!totalLen) return;
    var target = Math.floor(totalLen * EXTRA_FREE_FRACTION);
    var cum = 0, cutIdx = -1;
    for (var i = 0; i < children.length; i++) {
      var el = children[i];
      // Skip header/nav/footer/script/style
      var tag = el.tagName;
      if (tag === 'HEADER' || tag === 'NAV' || tag === 'FOOTER' || tag === 'SCRIPT' || tag === 'STYLE') continue;
      if (el.classList && (el.classList.contains('atlas-nav') || el.classList.contains('site-header') || el.id === 'tocNav')) continue;
      var l = el.textContent.replace(/\s+/g, '').length;
      if (cum + l >= target && cum > 0) { cutIdx = i; break; }
      cum += l;
    }
    if (cutIdx < 0) return; // content too short to truncate meaningfully
    var card = buildCard({
      kind: 'extra',
      kicker: 'Atlas 会員限定 — 号外',
      title: 'この先は Atlas 会員限定です。',
      desc: '号外記事の続き（残り約 ' + Math.round((1 - EXTRA_FREE_FRACTION) * 100) + '%）は有料会員向けコンテンツです。<br>市場の重要イベントを深掘りするAtlas独自の分析を、ぜひお楽しみください。'
    });
    // Add fade overlay before hiding rest
    var fade = document.createElement('div');
    fade.className = 'atlas-paywall-fade';
    var cutElement = children[cutIdx];
    cutElement.parentNode.insertBefore(fade, cutElement);
    cutElement.parentNode.insertBefore(card, cutElement);
    // Hide remaining children
    for (var j = cutIdx; j < children.length; j++) {
      var c = children[j];
      var ctag = c.tagName;
      if (ctag === 'FOOTER' || ctag === 'SCRIPT' || ctag === 'STYLE') continue;
      if (c.classList && (c.classList.contains('atlas-related-morning') || c.classList.contains('atlas-nav'))) continue;
      c.classList.add('atlas-paywall-gated-hide');
    }
  }

  // Full gate: show minimal preview (hero/intro) + paywall card covering rest.
  function applyGate(cfg) {
    ensureCss();
    var body = findArticleBody();
    // Preserve first 1-2 obvious "intro" elements (header + first section/paragraph)
    // Hide everything else in the main content area.
    var children = Array.prototype.slice.call(body.children);
    var kept = 0, maxKeep = 2;
    var insertAt = null;
    for (var i = 0; i < children.length; i++) {
      var el = children[i];
      var tag = el.tagName;
      if (tag === 'HEADER' || tag === 'NAV' || tag === 'FOOTER' || tag === 'SCRIPT' || tag === 'STYLE') continue;
      if (el.classList && (el.classList.contains('atlas-nav') || el.classList.contains('site-header'))) continue;
      if (kept < maxKeep) { kept++; continue; }
      // This is where we insert the paywall, and hide from here
      insertAt = el;
      break;
    }
    var titles = {
      morning: { kicker: 'Atlas 会員限定 — 過去の朝刊', title: 'この朝刊は Atlas 会員限定です。', desc: '当日・前日の朝刊は無料でご覧いただけますが、過去のアーカイブをお読みいただくには会員登録が必要です。<br>米国市場の動きを毎朝定点観測し、意思決定の土台に。' },
      special: { kicker: 'Atlas 会員限定 — 特集', title: 'この特集記事は Atlas 会員限定です。', desc: '財務・戦略・マクロ経済の観点から編集部が深掘りした長編分析記事です。<br>会員登録で、すべての特集をお楽しみいただけます。' },
      report: { kicker: 'Atlas 会員限定 — 決算分析', title: 'このレポートは Atlas 会員限定です。', desc: '主要7銘柄（NVDA/GOOGL/TSLA/MSFT/META/AMZN/AAPL）の直近四半期は無料でご覧いただけますが、<br>過去四半期や他の銘柄レポートをお読みいただくには会員登録が必要です。' }
    };
    var info = titles[cfg.kind] || { kicker: 'Atlas 会員限定', title: 'この記事は Atlas 会員限定です。', desc: '続きをお読みいただくには会員登録が必要です。' };
    var card = buildCard({ kind: cfg.kind, kicker: info.kicker, title: info.title, desc: info.desc });
    if (insertAt) {
      // Wrap kept preview in max-height wrapper for fade effect
      // Simpler: just insert card before insertAt, and hide everything after
      insertAt.parentNode.insertBefore(card, insertAt);
      for (var k = 0; k < children.length; k++) {
        var c = children[k];
        if (c === card) continue;
        var idx = Array.prototype.indexOf.call(c.parentNode.children, c);
        var cardIdx = Array.prototype.indexOf.call(card.parentNode.children, card);
        if (idx <= cardIdx) continue; // keep before card
        var ctag = c.tagName;
        if (ctag === 'FOOTER' || ctag === 'SCRIPT' || ctag === 'STYLE') continue;
        if (c.classList && (c.classList.contains('atlas-related-morning') || c.classList.contains('atlas-nav'))) continue;
        c.classList.add('atlas-paywall-gated-hide');
      }
    } else {
      // No content to preview; just append card to body
      body.appendChild(card);
    }
  }

  function main() {
    var cfg = readAccess();
    var status = resolveStatus(cfg);
    if (status === 'full') return;
    checkPro().then(function (isPro) {
      if (isPro) return;
      if (status === 'truncate') applyTruncate(cfg);
      else if (status === 'gated') applyGate(cfg);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', main, { once: true });
  } else {
    main();
  }
})();

</script>
<!-- /ATLAS-PAYWALL-SCRIPT -->
</body>
</html>
