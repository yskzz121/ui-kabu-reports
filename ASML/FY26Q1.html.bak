<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>ASML Holding N.V. (ASML) FY26 Q1 決算分析</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho+B1:wght@500;700;800&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<link rel="icon" type="image/png" href="../favicon.png">
<script>window.ATLAS_FX = { code:'JPY', symbol:'¥', rate: 152.5, eurRate: 165.0, date: '2026/4/16', fmt:'cjk-ja' };</script>
<style>
:root{
  --bg:#0d1117;--card:#161b22;--border:#30363d;--t1:#e6edf3;--t2:#8b949e;--t3:#6e7681;
  --gold:#B8912A;--gold2:#D4A843;--navy:#1A2540;--paper:#F5F2EC;
  --gl:#3fb950;--rl:#ff7b72;--blue:#58a6ff;--bbg:rgba(88,166,255,.12);--purple:#bc8cff;--alert:#8B2020;
  --text-sub:#8b949e;--card-border:#30363d;
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Noto Sans JP',sans-serif;background:var(--bg);color:var(--t1);line-height:1.7;padding:20px;max-width:1200px;margin:0 auto}
h1,h2,h3,.section-title{font-family:'Shippori Mincho B1','Noto Sans JP',serif}
.card-val,.score-num,.price,.val-card .price{font-family:'Inter','Noto Sans JP',sans-serif}

/* Header */
.header{background:linear-gradient(135deg,#1a2332 0%,#1A2540 50%,#0F1829 100%);border-bottom:1px solid rgba(184,145,42,0.15);padding:40px 20px 30px;text-align:center;position:relative;overflow:hidden;border-radius:14px;margin-bottom:28px}
.header::before{content:'';position:absolute;top:0;left:0;right:0;bottom:0;background:radial-gradient(ellipse at 30% 50%,rgba(184,145,42,0.08) 0%,transparent 60%),radial-gradient(ellipse at 70% 50%,rgba(184,145,42,0.06) 0%,transparent 60%)}
.header-content{position:relative;z-index:1}
.header h1{font-size:2.2em;font-weight:900;margin-bottom:4px}
.header .subtitle{color:var(--text-sub);font-size:1.1em}
.header .date{color:var(--text-sub);font-size:0.85em;margin-top:8px}
.header-logo-row{display:flex;align-items:center;justify-content:center;gap:16px;margin-bottom:8px}
.report-header-logo{height:48px;width:auto;max-width:180px;object-fit:contain;vertical-align:middle;margin-right:12px;opacity:.9;flex-shrink:0}
.ticker-badge{display:inline-block;background:rgba(184,145,42,0.15);border:1px solid rgba(184,145,42,0.3);border-radius:8px;padding:6px 16px;font-size:14px;color:var(--gold);margin-bottom:12px;letter-spacing:1px;font-family:'Inter',sans-serif}

/* Overview dropdown */
.overview-toggle-wrap{position:absolute;top:14px;right:18px;z-index:2;display:flex;gap:6px;align-items:center}
.overview-toggle-btn{background:rgba(184,145,42,0.12);border:1px solid rgba(184,145,42,0.35);color:#D4A843;font-family:'Noto Sans JP',sans-serif;font-size:.78rem;padding:6px 12px;border-radius:8px;cursor:pointer;letter-spacing:.5px;transition:all .2s;display:inline-flex;align-items:center;gap:6px}
.overview-toggle-btn:hover{background:rgba(184,145,42,0.22);color:#F5F2EC}
.overview-toggle-btn .chev{transition:transform .25s;display:inline-block}
.overview-toggle-btn.open .chev{transform:rotate(180deg)}
.overview-dropdown{max-height:0;overflow:hidden;transition:max-height .4s ease,opacity .3s ease,margin .3s ease;opacity:0;background:var(--card);border:1px solid rgba(184,145,42,0.2);border-radius:12px}
.overview-dropdown.open{max-height:1500px;opacity:1;margin:0 0 28px 0;padding:22px 26px}
.overview-dropdown h2{font-size:1rem;font-weight:700;margin-bottom:12px;display:flex;align-items:center;gap:8px;color:var(--gold2)}
.overview-dropdown p{font-size:.9rem;color:var(--t2);line-height:1.9;margin-bottom:10px}
.overview-dropdown .tags{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px}
.overview-dropdown .tag{font-size:.72rem;padding:3px 11px;border-radius:20px;background:rgba(184,145,42,.12);color:var(--gold2);border:1px solid rgba(184,145,42,.25)}
@media(max-width:768px){.overview-toggle-wrap{position:relative;top:auto;right:auto;margin-top:12px;text-align:center;justify-content:center}}

/* Score */
.score-section{text-align:center;padding:40px 20px;margin-bottom:32px;background:linear-gradient(135deg,rgba(184,145,42,.08),rgba(88,166,255,.04));border-radius:16px;border:1px solid var(--border)}
.score-badge{display:inline-flex;align-items:center;gap:14px;background:var(--card);border:2px solid var(--gold);border-radius:16px;padding:16px 32px;margin-bottom:14px}
.score-num{font-size:3rem;font-weight:900;color:var(--gold2)}
.score-icon{font-size:2.5rem}
.score-label{font-size:1.3rem;font-weight:700;color:var(--gold2)}
.score-desc{color:var(--t2);font-size:.9rem;margin-top:8px;max-width:820px;margin-left:auto;margin-right:auto;line-height:1.9}

/* Sections */
.section{margin-bottom:36px}
.section-title{font-size:1.15rem;font-weight:700;padding-bottom:12px;border-bottom:1px solid var(--border);margin-bottom:20px;display:flex;align-items:center;gap:8px}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px}
.grid-2{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:16px}
.card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:20px}
.card-label{font-size:.72rem;font-weight:500;color:var(--t3);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;font-family:'Inter',sans-serif}
.card-val{font-size:1.6rem;font-weight:700}
.card-sub{font-size:.8rem;color:var(--t2);margin-top:4px}
.pos{color:var(--gl)}.neg{color:var(--rl)}.neu{color:var(--t1)}.gold{color:var(--gold2)}

.chart-box{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:24px}
.chart-wrap{position:relative;height:300px}
.chart-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}

.insight{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:18px 22px;font-size:.9rem;line-height:1.9;color:var(--t2);margin-bottom:14px}
.insight strong{color:var(--t1)}

.risk-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.risk-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:20px}
.risk-card h3{font-size:.95rem;font-weight:700;margin-bottom:12px;display:flex;align-items:center;gap:6px}
.risk-card ul{list-style:none;padding:0}
.risk-card li{font-size:.85rem;color:var(--t2);padding:6px 0;border-bottom:1px solid rgba(48,54,61,.5);line-height:1.7}
.risk-card li:last-child{border-bottom:none}
.risk-card li::before{content:'•';margin-right:8px;font-weight:700;color:var(--gold2)}

.val-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.val-card{border-radius:14px;padding:24px;text-align:center;background:var(--card);border:1px solid var(--border)}
.val-card .scenario{font-size:.75rem;font-weight:700;letter-spacing:1px;margin-bottom:8px;color:var(--gold2)}
.val-card .price{font-size:2rem;font-weight:900;margin-bottom:6px;color:var(--gold2)}
.val-card .detail{font-size:.78rem;color:var(--t2);line-height:1.6}
.val-card .gap{font-size:.85rem;font-weight:700;margin-top:8px;font-family:'Inter',sans-serif}

.tbl{width:100%;border-collapse:collapse;font-size:.88rem}
.tbl th,.tbl td{padding:10px 14px;text-align:left;border-bottom:1px solid var(--border)}
.tbl th{color:var(--t3);font-weight:500;font-size:.75rem;text-transform:uppercase;letter-spacing:.5px;font-family:'Inter',sans-serif}
.tbl td{color:var(--t2)}
.tbl tr:hover td{background:rgba(184,145,42,.04)}

.footer{text-align:center;padding:32px 20px;border-top:1px solid var(--border);margin-top:40px;color:var(--t3);font-size:.75rem;line-height:1.8}

/* === Mobile Responsive === */
.tradingview-widget-container{max-width:100%;overflow-x:auto;-webkit-overflow-scrolling:touch}
@media(max-width:768px){
  body{padding:12px!important}
  .container{padding:12px}
  .header{padding:28px 16px}
  .header h1{font-size:1.4rem}
  .header .subtitle{font-size:.95em}
  .header-logo-row{flex-direction:column;gap:8px}
  .report-header-logo{height:36px}
  .ticker-badge{font-size:12px;padding:4px 12px}
  .grid,.metrics-grid{grid-template-columns:1fr 1fr}
  .val-grid,.val-cards,.risk-grid{grid-template-columns:1fr}
  .chart-wrap,.chart-container{height:250px}
  .section{padding:20px 16px}
  .card-grid{grid-template-columns:1fr 1fr}
  .two-col{grid-template-columns:1fr}
  .rc-grid{grid-template-columns:1fr}
  .saas-grid{grid-template-columns:1fr 1fr}
  .metrics-grid{grid-template-columns:1fr 1fr!important}
  .chart-row{grid-template-columns:1fr!important}
  .overview-grid{grid-template-columns:1fr!important}
  .tech-grid{grid-template-columns:1fr!important}
  table{display:block;overflow-x:auto;-webkit-overflow-scrolling:touch}
  .compare-table,.tech-table,.tbl{font-size:.78rem}
  .portal-link{padding:6px 10px;font-size:.7rem}
}
@media(max-width:480px){
  .grid,.metrics-grid,.card-grid,.saas-grid{grid-template-columns:1fr!important}
  .chart-row,.overview-grid,.tech-grid{grid-template-columns:1fr!important}
  .header h1{font-size:1.2rem}
  .score-big{font-size:3.5em}
  .score-label{font-size:1.2em}
  .section-title,.section-header{font-size:1rem}
}

/* === Accordion (mobile only) === */
.section[data-accordion]{position:relative}
.section[data-accordion] .section-title{cursor:pointer;user-select:none;padding-right:36px}
.section[data-accordion] .section-title::after{content:'▼';position:absolute;right:20px;top:28px;font-size:.7em;color:var(--text-sub);transition:transform .25s}
.section[data-accordion].collapsed .section-title::after{transform:rotate(-90deg)}
.section[data-accordion] .section-body{overflow:visible;transition:max-height .35s ease,opacity .25s ease;max-height:5000px;opacity:1}
.section[data-accordion].collapsing .section-body{overflow:hidden}
.section[data-accordion].collapsed .section-body{max-height:0;overflow:hidden;opacity:0;margin:0;padding:0}

/* === TOC Nav (mobile only) === */
.toc-nav{display:none}
@media(max-width:768px){
  .toc-nav{display:block;position:fixed;bottom:0;left:0;right:0;z-index:998;background:#1A2540;border-top:1px solid rgba(184,145,42,0.15);box-shadow:0 -2px 12px rgba(0,0,0,.3)}
  .toc-toggle{position:fixed;bottom:16px;right:16px;z-index:999;width:48px;height:48px;border-radius:50%;background:#B8912A;color:#0F1829;border:none;font-size:1.2rem;cursor:pointer;box-shadow:0 2px 12px rgba(0,0,0,.4);display:flex;align-items:center;justify-content:center;transition:all .2s}
  .toc-toggle.open{border-radius:12px 12px 0 0;bottom:0;right:0;left:0;width:100%;height:44px;font-size:.9rem}
  .toc-menu{max-height:0;overflow:hidden;transition:max-height .3s ease}
  .toc-menu.open{max-height:60vh;overflow-y:auto;-webkit-overflow-scrolling:touch}
  .toc-list{list-style:none;padding:8px 0;margin:0}
  .toc-list li{border-bottom:1px solid #21262d}
  .toc-list li:last-child{border-bottom:none}
  .toc-list a{display:flex;align-items:center;gap:10px;padding:12px 20px;color:#e6edf3;text-decoration:none;font-size:.85rem;transition:background .15s}
  .toc-list a:hover,.toc-list a:active{background:rgba(184,145,42,.12)}
  .toc-list .toc-icon{font-size:1.1em;flex-shrink:0;width:24px;text-align:center}
  .toc-list .toc-label{flex:1}
  .toc-expand-all{display:flex;justify-content:center;gap:12px;padding:10px 16px;border-bottom:1px solid #21262d}
  .toc-expand-all button{font-family:'Noto Sans JP',sans-serif;font-size:.75rem;padding:4px 14px;border-radius:6px;border:1px solid #30363d;background:transparent;color:#8b949e;cursor:pointer}
  .toc-expand-all button:active{background:#B8912A;color:#0F1829}
  body{padding-bottom:60px!important}
}

/* Portal link */
.portal-link{position:fixed;top:16px;left:16px;z-index:999;display:flex;align-items:center;gap:6px;padding:8px 14px;border-radius:8px;background:#1A2540;border:1px solid rgba(184,145,42,0.2);color:#D4A843;text-decoration:none;font-size:.78rem;font-weight:500;font-family:"Noto Sans JP",sans-serif;transition:all .15s;box-shadow:0 2px 8px rgba(0,0,0,.15)}
.portal-link:hover{background:#B8912A;color:#0F1829;border-color:#B8912A}
.portal-link svg{flex-shrink:0}

/* Atlas Floating Tools */
.atlas-floating-tools{position:fixed;top:16px;right:16px;z-index:999;display:inline-flex;align-items:center;gap:6px;padding:6px 8px;border-radius:10px;background:rgba(26,37,64,.92);border:1px solid rgba(184,145,42,0.2);box-shadow:0 2px 8px rgba(0,0,0,.25);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px)}
.atlas-floating-tools .currency-toggle,.atlas-floating-tools .theme-toggle-btn{background:transparent;border:1px solid rgba(255,255,255,0.18);cursor:pointer;padding:5px 9px;border-radius:6px;color:rgba(255,255,255,0.78);font-size:12px;line-height:1;display:inline-flex;align-items:center;justify-content:center;height:28px;transition:all .15s;font-family:'Inter','Noto Sans JP',sans-serif;font-weight:600;white-space:nowrap}
.atlas-floating-tools .currency-toggle:hover,.atlas-floating-tools .theme-toggle-btn:hover{border-color:rgba(184,145,42,0.55);color:#D4A843;background:rgba(184,145,42,0.08)}
.atlas-floating-tools .currency-toggle .cur-active{color:#D4A843;font-weight:800}
.atlas-floating-tools .currency-toggle .cur-inactive{color:inherit;opacity:.5}
.atlas-floating-tools .currency-toggle .cur-sep{opacity:.35;margin:0 1px;font-weight:400}
.atlas-floating-tools .currency-toggle.jpy-mode,.atlas-floating-tools .currency-toggle.local-mode{border-color:rgba(184,145,42,0.6);background:rgba(184,145,42,0.12)}
.atlas-floating-tools .theme-toggle-btn{font-size:14px;min-width:32px}
.cur-val{transition:color .2s}
.cur-val.jpy-mode,.cur-val.local-mode{color:#D4A843;font-weight:700}

/* Light Theme */
html[data-theme="light"] body{background:#F5F2EC!important;color:#1A2540!important}
html[data-theme="light"] .container,html[data-theme="light"] .section,html[data-theme="light"] .card,html[data-theme="light"] .risk-card,html[data-theme="light"] .chart-box,html[data-theme="light"] .insight,html[data-theme="light"] .price-panel,html[data-theme="light"] .consensus-panel,html[data-theme="light"] .val-card,html[data-theme="light"] .overview-dropdown{background:#FDFCFA!important;border-color:rgba(26,37,64,0.12)!important;color:#1A2540!important;box-shadow:0 1px 4px rgba(26,37,64,.06)}
html[data-theme="light"] .header{background:linear-gradient(135deg,#1a2332 0%,#1A2540 50%,#0F1829 100%)!important}
html[data-theme="light"] h1,html[data-theme="light"] h2,html[data-theme="light"] h3,html[data-theme="light"] h4{color:#1A2540!important}
html[data-theme="light"] .header h1,html[data-theme="light"] .header h2,html[data-theme="light"] .header *{color:#F5F2EC!important}
html[data-theme="light"] .header .subtitle,html[data-theme="light"] .header .date{color:rgba(245,242,236,0.75)!important}
html[data-theme="light"] table,html[data-theme="light"] th,html[data-theme="light"] td{border-color:rgba(26,37,64,0.15)!important;color:#1A2540!important}
html[data-theme="light"] .atlas-floating-tools{background:rgba(253,252,250,.92);border-color:rgba(26,37,64,0.15)}
html[data-theme="light"] .atlas-floating-tools .currency-toggle,html[data-theme="light"] .atlas-floating-tools .theme-toggle-btn{color:rgba(26,37,64,0.78);border-color:rgba(26,37,64,0.2)}
html[data-theme="light"] .portal-link{background:#FDFCFA!important;border-color:rgba(26,37,64,0.15)!important;color:#B8912A!important}

/* Top Panel */
.top-panel{display:grid;grid-template-columns:minmax(260px,1fr) 2fr;gap:16px;margin-bottom:28px}
.price-panel,.consensus-panel{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:22px}
.price-panel h3,.consensus-panel h3{font-size:.78rem;color:var(--gold2);letter-spacing:1px;text-transform:uppercase;margin-bottom:14px;font-family:'Inter','Noto Sans JP',sans-serif;font-weight:700}
.price-row{display:flex;justify-content:space-between;align-items:baseline;padding:10px 0;border-bottom:1px dashed rgba(48,54,61,.7)}
.price-row:last-child{border-bottom:none}
.price-row .lbl{font-size:.78rem;color:var(--t2)}
.price-row .val{font-size:1.3rem;font-weight:800;color:var(--t1);font-family:'Inter',sans-serif}
.price-row .sub{font-size:.72rem;color:var(--t3);display:block;margin-top:2px}

.consensus-table{width:100%;border-collapse:collapse;font-size:.85rem}
.consensus-table th,.consensus-table td{padding:10px 8px;text-align:left;border-bottom:1px solid var(--border)}
.consensus-table th{font-family:'Inter',sans-serif;font-size:.7rem;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;font-weight:600}
.consensus-table td{color:var(--t2)}
.consensus-table td.val{color:var(--t1);font-weight:700;font-family:'Inter',sans-serif}
.consensus-table td.beat-pct{color:var(--gl);font-weight:700;font-family:'Inter',sans-serif}

.beat-lamp{display:inline-block;width:12px;height:12px;border-radius:50%;background:#2ecc71;box-shadow:0 0 8px #2ecc71,0 0 16px rgba(46,204,113,.4);animation:pulse-green 1.5s ease-in-out infinite;vertical-align:middle;margin-right:6px}
@keyframes pulse-green{0%,100%{opacity:1;box-shadow:0 0 8px #2ecc71,0 0 16px rgba(46,204,113,.4)}50%{opacity:.5;box-shadow:0 0 4px #2ecc71,0 0 8px rgba(46,204,113,.2)}}
.beat-text{color:#D4A843;font-weight:700;letter-spacing:1px;animation:glow-gold 2.5s ease-in-out infinite;font-family:'Inter',sans-serif}
@keyframes glow-gold{0%,100%{opacity:1;text-shadow:0 0 8px rgba(212,168,67,.6)}50%{opacity:.6;text-shadow:0 0 4px rgba(212,168,67,.3)}}
@media(max-width:768px){.top-panel{grid-template-columns:1fr}.consensus-table{font-size:.72rem}.consensus-table th,.consensus-table td{padding:8px 4px}}

/* YoY/QoQ detail */
.delta-detail{display:block;font-size:.78rem;color:var(--text-sub);margin-top:6px;line-height:1.5}
.delta-detail .delta-row{display:block;margin-top:2px}
.delta-detail .delta-pct{font-weight:700;font-family:'Inter',sans-serif}
.delta-detail .delta-abs{opacity:.85;font-family:'Inter',sans-serif}
.delta-detail .prior-value{display:block;margin-left:14px;opacity:.65;font-size:.92em;font-family:'Inter',sans-serif}
.delta-detail .delta-pct.pos{color:var(--gl)}
.delta-detail .delta-pct.neg{color:var(--rl)}
</style>
<!-- ATLAS-PAYWALL-META -->
<meta name="atlas-access" content='{"kind":"report","ticker":"ASML","isLatest":true}'>
<!-- /ATLAS-PAYWALL-META -->
</head>
<body>

<!-- ATLAS-NAV-START -->
<header class="atlas-nav" data-atlas-nav>
  <div class="atlas-nav-inner">
    <a href="https://atlas-financials.jp/" class="atlas-nav-brand" aria-label="Atlas ホーム">
      <span class="atlas-nav-logo">Atlas<span class="atlas-nav-dot">.</span></span>
      <span class="atlas-nav-tag">U.S. Market Intelligence</span>
    </a>
    <nav class="atlas-nav-links" aria-label="グローバルナビ">
      <a href="https://atlas-financials.jp/" data-path="/">ホーム</a>
      <a href="https://atlas-financials.jp/news/" data-path="/news/">ニュース</a>
      <a href="https://atlas-financials.jp/reports/" data-path="/reports/">決算分析</a>
      <a href="https://atlas-financials.jp/news/glossary/" data-path="/news/glossary/">経済辞書</a>
      <a href="https://atlas-financials.jp/reports/faq.html" data-path="/reports/faq.html">FAQ</a>
      <a href="https://atlas-financials.jp/login" class="atlas-nav-login-link" data-atlas-login-cta>ログイン</a>
      <a href="https://atlas-financials.jp/signup" class="atlas-nav-cta" data-atlas-signup-cta>無料ではじめる</a>
      <div class="atlas-nav-user" data-atlas-nav-user style="display:none">
        <button class="atlas-nav-avatar-btn" type="button" aria-expanded="false" aria-haspopup="menu" data-atlas-nav-user-btn>
          <span class="atlas-nav-avatar" data-atlas-nav-avatar>?</span>
          <span class="atlas-nav-username" data-atlas-nav-username></span>
          <span class="atlas-nav-caret" aria-hidden="true">▾</span>
        </button>
        <div class="atlas-nav-menu" role="menu" data-atlas-nav-menu aria-hidden="true">
          <div class="atlas-nav-menu-head">
            <div class="atlas-nav-menu-name" data-atlas-nav-menu-name></div>
            <div class="atlas-nav-menu-email" data-atlas-nav-menu-email></div>
            <span class="atlas-nav-menu-plan" data-atlas-nav-menu-plan></span>
          </div>
