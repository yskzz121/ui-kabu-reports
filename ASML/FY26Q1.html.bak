          <td>EPS（希薄化後 / Diluted）</td>
          <td>€6.00</td>
          <td class="val">€7.15</td>
          <td class="beat-pct"><span class="beat-lamp"></span>+19.2% <span class="beat-text">ビート</span></td>
        </tr>
        <tr>
          <td>Q2 2026 売上ガイダンス（中央値）</td>
          <td>€9.07B</td>
          <td class="val">€8.7B</td>
